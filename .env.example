# Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/openai/v1
AZURE_OPENAI_API_KEY=your_azure_openai_api_key
AZURE_OPENAI_DEPLOYMENT=gpt-realtime-mini
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-5-mini

# Azure AI Speech
AZURE_SPEECH_KEY=your_azure_speech_key
AZURE_SPEECH_REGION=westus2

# Twilio
TWILIO_ACCOUNT_SID=ACXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+10000000000

# Targets
TARGET_NUMBER=+10000000000
TEST_TARGET_NUMBER=+10000000000

# Server (fill in after starting tunnel)
SERVER_DOMAIN=your-subdomain.loca.lt
PORT=8080
LOCALTUNNEL_URL=https://your-subdomain.loca.lt
